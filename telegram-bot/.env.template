# ALIRA Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=ALIRA_TELEGRAM_BOT_TOKEN

# Admin Telegram Chat ID (your personal Telegram ID for receiving admin notifications)
# Get this by sending a message to @userinfobot
ADMIN_CHAT_ID=your_admin_chat_id

# Admin username (for display purposes)
ADMIN_USERNAME=alira_admin

# Database (SQLite will be created automatically)
DATABASE_PATH=alira.db

# Environment
DEBUG=false
LOG_LEVEL=INFO
